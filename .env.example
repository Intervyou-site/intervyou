# IntervYou Environment Configuration
# Copy this file to .env and fill in your actual values
# ⚠️ NEVER commit .env files to version control!

# Security (REQUIRED)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-in-production

# Database
# SQLite (Development - default):
# DATABASE_URL=sqlite:///./database.db

# PostgreSQL (Recommended for production and development):
# Note: URL-encode special characters in password (% becomes %25, & becomes %26, etc.)
DATABASE_URL=postgresql://intervyou_user:your_secure_password@localhost:5432/intervyou

# Async PostgreSQL (optional, for async endpoints):
# ASYNC_DATABASE_URL=postgresql+asyncpg://intervyou_user:your_secure_password@localhost:5432/intervyou

# Email Configuration (for password reset)
# ⚠️ Use app-specific password, not your main password
# Generate at: https://myaccount.google.com/apppasswords
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password-here
MAIL_FROM=no-reply@intervyou.com
MAIL_FROM_NAME=IntervYou Support
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# OAuth Social Login (Google)
# Get credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OpenAI API (for AI evaluation)
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: SerpAPI (for question generation)
# Get key at: https://serpapi.com/manage-api-key
SERPAPI_KEY=your-serpapi-key-here

# Optional: Hugging Face (for AI models)
# Get token at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=your-huggingface-token-here

# Optional: Copyleaks (for plagiarism detection)
COPYLEAKS_API_KEY=your-copyleaks-api-key
COPYLEAKS_EMAIL=your-copyleaks-email@example.com
COPYLEAKS_WEBHOOK_URL=https://your-domain.com/copyleaks/webhook

# Environment
ENVIRONMENT=development
# Set to 'production' for stricter CSP and security headers

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://localhost:3000

# OTP Configuration
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_REQUEST_COOLDOWN=60

# Hugging Face Configuration
USE_HUGGINGFACE=true
HUGGINGFACE_FALLBACK=true  # Use HF as fallback if OpenAI fails
