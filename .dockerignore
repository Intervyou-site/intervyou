# Database files (use external DB)
*.db
*.sqlite
*.sqlite3
database.db

# Large media files only (exclude by extension, not directory)
# This allows CSS, JS, images to be included while excluding large audio/video
*.mp3
*.wav
*.webm
*.mp4
*.avi
*.mov
*.flv
*.wmv

# But keep small audio files in specific locations if needed
# (Docker will include everything else in static/ by default)

# Model files (download at runtime if needed)
# Exclude ML model binaries but keep Python model definitions
*.bin
*.safetensors
*.onnx
*.h5
*.pkl
*.joblib
# Keep models/ directory for Python code (practice_models.py, etc.)

# Docker files (not needed inside container)
Dockerfile*
docker-compose*.yml
.dockerignore
*.ps1
*.sh

# Environment files (set via platform)
.env*
!.env.example

# Cache directories
.cache/
node_modules/
.npm/

# Windows specific
Thumbs.db
desktop.ini

# Mac specific
.DS_Store
.AppleDouble
.LSOverride

# Azure/deployment scripts
azure-setup.*
docker-*.ps1
docker-*.sh
manage-docker.ps1